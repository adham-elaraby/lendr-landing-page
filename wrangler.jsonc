{
  "name": "lendr-landing-page",
  "main": "./dist/_worker.js/index.js",
  "build": {
    "command": "npm run build"
  },
  "compatibility_date": "2026-04-14",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
