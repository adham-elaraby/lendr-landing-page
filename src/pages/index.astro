---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/sections/Section.astro";
import mapUnite from "../assets/pics/map-unite.png";

const painPoints = [
  {
    title: "Expensive purchases",
    text: "People buy tools they use once, like drills, camping tents, and sewing machines.",
  },
  {
    title: "Home clutter",
    text: "Occasional-use items sit in closets and basements, taking space all year.",
  },
  {
    title: "Unnecessary waste",
    text: "Buying everything new increases overproduction and avoidable emissions.",
  },
];

const steps = [
  {
    title: "Search",
    text: "Find items near you by category, distance, and availability.",
  },
  {
    title: "Book",
    text: "Choose your dates and send a rental request in seconds.",
  },
  {
    title: "Use",
    text: "Pick up the item nearby and use it when you actually need it.",
  },
  {
    title: "Return",
    text: "Return on time and rate your experience to build trust.",
  },
];

const features = [
  {
    title: "Item listings",
    text: "Clear item photos, details, and pricing from local lenders.",
  },
  {
    title: "Search and filters",
    text: "Filter by location, category, date range, and price.",
  },
  {
    title: "Booking system",
    text: "Date-based booking flow with quick request approval.",
  },
  {
    title: "Ratings and trust",
    text: "Profile ratings and reviews after every completed rental.",
  },
  {
    title: "Location-first results",
    text: "Hyper-local discovery so pickup stays fast and practical.",
  },
  {
    title: "Return tracking",
    text: "Simple reminders keep returns smooth for renters and lenders.",
  },
];

const users = [
  {
    title: "Students",
    text: "Save money by renting tools and event gear only when needed.",
  },
  {
    title: "Young professionals",
    text: "Get convenience without buying and storing rarely-used items.",
  },
  {
    title: "Families",
    text: "Access occasional-use products without long-term clutter.",
  },
  {
    title: "Lenders",
    text: "Earn from unused items while helping nearby neighbors.",
  },
];

const trustPoints = [
  "Reputation-based ratings",
  "Clear user profiles",
  "Secure payments",
  "Verified users on roadmap",
];

const faqs = [
  {
    q: "What if an item is damaged?",
    a: "Damage reports are handled through a guided flow with evidence, timestamps, and support follow-up.",
  },
  {
    q: "How do payments work?",
    a: "You pay securely in-app. Lenders receive payment after successful pickup and return confirmation.",
  },
  {
    q: "Where does Lendr launch first?",
    a: "We start with pilot neighborhoods and campuses where local density makes borrowing fast and reliable.",
  },
];
---

<MainLayout
  title="Lendr | Borrow Instead of Buy"
  description="Lendr helps people rent everyday items from neighbors nearby. Save money, reduce waste, and keep life uncluttered."
>
  <Section id="home">
    <div class="grid items-center gap-10 pt-8 md:pt-16 lg:grid-cols-2">
      <div class="space-y-6">
        <p class="inline-block rounded-full bg-green px-4 py-2 text-sm font-medium">
          Community rental platform
        </p>
        <h1 class="text-4xl font-medium leading-tight sm:text-5xl lg:text-6xl">
          Borrow Instead of Buy
        </h1>
        <p class="max-w-[640px] text-lg leading-relaxed text-zinc-700">
          Lendr connects you with your local community to rent tools, gear, and
          everyday items - cheaper, smarter, and more sustainable.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="#get-started"
            class="inline-flex items-center justify-center rounded-2xl bg-dark px-7 py-4 text-white transition duration-200 hover:-translate-y-0.5 hover:bg-black"
          >
            Get Started
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center rounded-2xl border border-zinc-900 bg-white px-7 py-4 transition duration-200 hover:-translate-y-0.5 hover:bg-zinc-100"
          >
            Browse Items
          </a>
        </div>
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-zinc-200 p-4 shadow-sm">
            <p class="text-2xl font-medium">2,000+</p>
            <p class="text-sm text-zinc-600">Items in pilot areas</p>
          </div>
          <div class="rounded-2xl border border-zinc-200 p-4 shadow-sm">
            <p class="text-2xl font-medium">35%</p>
            <p class="text-sm text-zinc-600">Average user savings</p>
          </div>
          <div class="rounded-2xl border border-zinc-200 p-4 shadow-sm">
            <p class="text-2xl font-medium">24h</p>
            <p class="text-sm text-zinc-600">Typical booking lead time</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1545239351-1141bd82e8a6?auto=format&fit=crop&w=1200&q=80"
          alt="Neighbors sharing tools and outdoor items"
          class="h-full min-h-[360px] w-full rounded-[32px] object-cover shadow-[0_20px_50px_rgba(0,0,0,0.12)]"
          loading="eager"
        />
        <div class="absolute -bottom-6 left-6 right-6 rounded-3xl border border-zinc-200 bg-white/95 p-4 shadow-lg backdrop-blur">
          <p class="text-sm font-medium text-zinc-900">Nearby right now</p>
          <div class="mt-2 flex flex-wrap gap-2 text-sm">
            <span class="rounded-full bg-zinc-100 px-3 py-1">Cordless drill - 1.2km</span>
            <span class="rounded-full bg-zinc-100 px-3 py-1">Camping tent - 0.8km</span>
            <span class="rounded-full bg-zinc-100 px-3 py-1">Baby carrier - 1.9km</span>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section id="problem">
    <div class="mt-28">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-center">
        <h2 class="greenhead w-fit text-3xl">The Problem</h2>
        <p class="max-w-[700px] text-zinc-700">
          Most people pay full price for things they barely use.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          painPoints.map((item) => (
            <article class="group rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-green text-sm font-medium">
                !
              </div>
              <h3 class="text-2xl font-medium">{item.title}</h3>
              <p class="mt-3 text-zinc-700">{item.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="solution">
    <div class="mt-28 grid items-center gap-8 lg:grid-cols-2">
      <img
        src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80"
        alt="People in a local community discussing and sharing"
        class="h-[360px] w-full rounded-[30px] object-cover shadow-[0_16px_40px_rgba(0,0,0,0.14)]"
        loading="lazy"
      />
      <div>
        <h2 class="text-3xl font-medium sm:text-4xl">
          Lendr lets you rent everyday items from people nearby.
        </h2>
        <p class="mt-4 text-zinc-700">
          We make borrowing simple with a local-first marketplace designed for
          daily life.
        </p>
        <ul class="mt-6 grid gap-3">
          <li class="rounded-2xl border border-zinc-200 bg-gray p-4">
            <strong>Local:</strong> Hyper-local neighborhoods and campus-friendly pickup.
          </li>
          <li class="rounded-2xl border border-zinc-200 bg-gray p-4">
            <strong>Easy:</strong> Search, book, and coordinate in a few taps.
          </li>
          <li class="rounded-2xl border border-zinc-200 bg-gray p-4">
            <strong>Trusted:</strong> Ratings, profiles, and secure payment flow.
          </li>
        </ul>
      </div>
    </div>
  </Section>

  <Section id="how-it-works">
    <div class="mt-28">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-center">
        <h2 class="greenhead w-fit text-3xl">How It Works</h2>
        <p class="max-w-[700px] text-zinc-700">
          A clear 4-step flow for renters and lenders.
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <article class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
              <p class="text-sm font-medium text-zinc-500">Step {i + 1}</p>
              <h3 class="mt-2 text-2xl font-medium">{step.title}</h3>
              <p class="mt-3 text-zinc-700">{step.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="features">
    <div class="mt-28">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-center">
        <h2 class="greenhead w-fit text-3xl">Features</h2>
        <p class="max-w-[700px] text-zinc-700">
          Core capabilities for a fast, practical rental experience.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {
          features.map((feature, i) => (
            <article class={`rounded-[30px] border p-7 transition duration-300 hover:-translate-y-1 hover:shadow-xl ${
              i % 3 === 1
                ? "border-green bg-green"
                : i % 3 === 2
                  ? "border-dark bg-dark text-gray"
                  : "border-zinc-200 bg-white"
            }`}>
              <h3 class="text-2xl font-medium">{feature.title}</h3>
              <p class="mt-3">{feature.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="users">
    <div class="mt-28">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-center">
        <h2 class="greenhead w-fit text-3xl">Who Lendr Is For</h2>
        <p class="max-w-[700px] text-zinc-700">
          Built for real people with real occasional-use needs.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          users.map((user) => (
            <article class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
              <h3 class="text-xl font-medium">{user.title}</h3>
              <p class="mt-3 text-zinc-700">{user.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="value">
    <div class="mt-28 grid gap-6 lg:grid-cols-3">
      <article class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <h3 class="text-2xl font-medium">Save Money</h3>
        <p class="mt-3 text-zinc-700">No need to buy expensive tools for one-time jobs.</p>
      </article>
      <article class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <h3 class="text-2xl font-medium">Sustainable</h3>
        <p class="mt-3 text-zinc-700">Fewer products bought, less waste produced, more reuse.
        </p>
      </article>
      <article class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <h3 class="text-2xl font-medium">Community</h3>
        <p class="mt-3 text-zinc-700">Neighbors helping neighbors through useful local sharing.</p>
      </article>
    </div>
  </Section>

  <Section id="trust">
    <div class="mt-28 rounded-[36px] bg-dark p-8 text-gray md:p-12">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div class="lg:pt-4">
          <h2 class="text-3xl font-medium text-white">Trust and Safety First</h2>
          <p class="mt-4 text-zinc-300">
            Trust is the key to local sharing. Lendr starts with practical,
            transparent safeguards from day one.
          </p>
          <ul class="mt-6 grid gap-3">
            {
              trustPoints.map((point) => (
                <li class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-4">{point}</li>
              ))
            }
          </ul>
        </div>
        <div class="grid gap-5 lg:pt-4">
          <article class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-5 shadow-[0_12px_24px_rgba(0,0,0,0.28)]">
            <p class="text-zinc-200">
              "I borrowed a drill 15 minutes away instead of buying one for 90 EUR. It was fast and simple."
            </p>
            <p class="mt-3 text-sm text-zinc-400">- Early pilot user</p>
          </article>
          <article class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-5 shadow-[0_12px_24px_rgba(0,0,0,0.28)]">
            <p class="text-zinc-200">
              "Our model is simple: we take a small fee per rental. No upfront cost. You only pay when you use."
            </p>
            <p class="mt-3 text-sm text-zinc-400">- Lendr team</p>
          </article>
        </div>
      </div>
    </div>
  </Section>

  <Section id="local">
    <div class="mt-28 grid items-center gap-8 pb-6 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-medium">Start in your neighborhood</h2>
        <p class="mt-4 text-zinc-700">
          We focus on dense local communities first, where short pickup distances
          make sharing truly convenient.
        </p>
        <p class="mt-4 inline-flex rounded-full border border-green/40 bg-green/20 px-4 py-2 text-sm text-zinc-800">
          Launching first in UNITE partner university cities, an alliance of our universities.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="rounded-full border border-zinc-300 px-4 py-2 text-sm">Darmstadt city center</span>
          <span class="rounded-full border border-zinc-300 px-4 py-2 text-sm">TU campus area</span>
          <span class="rounded-full border border-zinc-300 px-4 py-2 text-sm">Bessungen pilot</span>
        </div>
      </div>
      <div class="rounded-[32px] border border-zinc-700/40 bg-white p-3 shadow-[0_22px_46px_rgba(0,0,0,0.18)]">
        <Image
          src={mapUnite}
          alt="Map of partner universities and local rollout clusters"
          class="h-[340px] w-full rounded-[24px] bg-white object-contain"
          loading="lazy"
        />
      </div>
    </div>
  </Section>

  <Section id="faq">
    <div class="mt-28">
      <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-center">
        <h2 class="greenhead w-fit text-3xl">FAQ</h2>
        <p class="max-w-[700px] text-zinc-700">
          Quick answers before you start.
        </p>
      </div>
      <div class="grid gap-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
              <summary class="cursor-pointer list-none pr-8 text-lg font-medium">
                {faq.q}
              </summary>
              <p class="mt-3 text-zinc-700">{faq.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="get-started">
    <div class="my-24 rounded-[34px] border border-green bg-green p-8 md:p-12">
      <div class="grid items-center gap-6 lg:grid-cols-[1fr_auto]">
        <div>
          <h2 class="text-3xl font-medium sm:text-4xl">Start Sharing Today</h2>
          <p class="mt-3 max-w-[700px] text-zinc-800">
            Join the first Lendr communities and help build a trusted local sharing economy.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="#"
            class="inline-flex items-center justify-center rounded-2xl bg-dark px-6 py-4 text-white transition duration-200 hover:-translate-y-0.5 hover:bg-black"
          >
            Join Lendr
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center rounded-2xl border border-zinc-900 bg-white px-6 py-4 transition duration-200 hover:-translate-y-0.5 hover:bg-zinc-100"
          >
            Explore Items
          </a>
        </div>
      </div>
    </div>
  </Section>
</MainLayout>
