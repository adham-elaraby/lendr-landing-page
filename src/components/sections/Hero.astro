---
import { Image } from "astro:assets";
import Section from "./Section.astro";
import HeroIlust from "../../assets/pics/hero.svg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h1 class="text-4xl font-medium leading-none md:text-6xl text-center md:text-left">Rent Anything You <br> Need, From <br> People Nearby</h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12">Lendr connects you with your local community to rent tools, gear, and everyday items — cheaper, smarter, and more sustainable.</p>
            <div class="w-full justify-center md:justify-start items-center flex flex-col sm:flex-row gap-4">
                <a href="#getstarted" class="px-8 py-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl text-center text-white border text-xl font-normal leading-7">Get Started</a>
                <a href="#browse" class="px-8 py-5 bg-white hover:bg-zinc-100 rounded-2xl text-center text-black border border-zinc-900 text-xl font-normal leading-7">Browse Items</a>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <Image src={HeroIlust} alt="Hero Ilustration" loading="eager" />
    </div>
</div>
</Section>
