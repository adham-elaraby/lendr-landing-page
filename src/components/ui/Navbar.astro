---
const menuitems = [
  { href: "#problem", label: "Problem" },
  { href: "#how-it-works", label: "How it works" },
  { href: "#features", label: "Features" },
  { href: "#trust", label: "Trust" },
  { href: "#faq", label: "FAQ" },
];

const navButton = { href: "#get-started", label: "Join Lendr" };
---

<div class="mt-20">
  <nav class="fixed left-0 top-0 z-50 w-full border-b border-zinc-100 bg-white/95 backdrop-blur">
    <header class="mx-auto flex max-w-[1280px] items-center justify-between px-5 py-5">
      <a href="#home" class="flex items-center gap-2 text-2xl font-medium">
        <span class="inline-block h-3 w-3 rounded-full bg-green"></span>
        Lendr
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-zinc-300 lg:hidden"
        aria-label="Toggle menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-6 w-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="hidden h-6 w-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <div id="menu-items" class="absolute left-0 top-full hidden w-full border-b border-zinc-200 bg-white lg:static lg:flex lg:w-auto lg:items-center lg:gap-7 lg:border-0">
        <ul class="flex flex-col gap-1 p-5 lg:flex-row lg:items-center lg:gap-7 lg:p-0">
          {
            menuitems.map((item) => (
              <li>
                <a href={item.href} class="mobile-nav-link block rounded-lg px-3 py-2 text-zinc-700 transition hover:bg-zinc-100 hover:text-black" data-close-menu="true">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="px-5 pb-5 lg:p-0">
          <a href={navButton.href} class="mobile-nav-link inline-flex w-full items-center justify-center rounded-2xl border border-zinc-900 bg-white px-6 py-3 transition hover:bg-black hover:text-white lg:w-auto" data-close-menu="true">
            {navButton.label}
          </a>
        </div>
      </div>
    </header>
  </nav>
</div>

<script is:inline>
  const menuToggle = document.getElementById("menu-toggle");
  const menuItems = document.getElementById("menu-items");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");
  const closeMenuItems = document.querySelectorAll('[data-close-menu="true"]');

  menuToggle?.addEventListener("click", () => {
    menuItems?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  closeMenuItems.forEach((item) => {
    item.addEventListener("click", () => {
      menuItems?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>