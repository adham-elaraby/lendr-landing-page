---
const links = [
  { name: "How it works", href: "#how-it-works" },
  { name: "Features", href: "#features" },
  { name: "Trust", href: "#trust" },
  { name: "FAQ", href: "#faq" },
];
---

<footer class="px-5 pb-8">
  <div class="mx-auto w-full max-w-[1280px]">
    <div class="rounded-[36px] bg-dark px-6 py-10 text-gray md:px-10 md:py-12">
      <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
        <a href="#home" class="flex items-center gap-2 text-2xl font-medium text-white">
          <span class="inline-block h-3 w-3 rounded-full bg-green"></span>
          Lendr
        </a>
        <ul class="flex flex-wrap gap-4 text-zinc-300">
          {
            links.map((link) => (
              <li>
                <a class="rounded-lg px-3 py-2 transition hover:bg-zinc-800 hover:text-white" href={link.href}>
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-5">
          <p class="text-lg font-medium text-white">Start local</p>
          <p class="mt-2 text-zinc-300">
            Built for neighborhood-level borrowing first, then expanded city by city.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-5">
          <p class="text-lg font-medium text-white">Contact</p>
          <p class="mt-2 text-zinc-300">lendr@ae0x.dev</p>
          <p class="text-zinc-300">Darmstadt, Germany</p>
        </div>
        <form class="rounded-2xl border border-zinc-700 bg-zinc-900/60 p-5">
          <label for="waitlist-email" class="text-lg font-medium text-white">Join waitlist</label>
          <div class="mt-3 flex flex-col gap-2 sm:flex-row">
            <input
              id="waitlist-email"
              type="email"
              placeholder="you@email.com"
              class="w-full rounded-xl border border-zinc-600 bg-zinc-950 px-4 py-3 text-zinc-100 placeholder:text-zinc-500 focus:border-green focus:outline-none"
            />
            <button type="submit" class="rounded-xl bg-green px-4 py-3 font-medium text-black transition hover:bg-[#a6f15a]">
              Notify me
            </button>
          </div>
        </form>
      </div>

      <div class="mt-8 border-t border-zinc-700 pt-6 text-sm text-zinc-400">
        <p>2026 Lendr. Borrow instead of buy.</p>
      </div>
    </div>
  </div>
</footer>
